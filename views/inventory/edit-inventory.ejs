<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<h1><%= title %></h1>

<section class="inventory-panel inventory-panel--wide">
  <p class="form-note">
    Review the current details below, make your changes, and submit the form to update this vehicle.
  </p>

  <form action="/inv/update" method="post" class="inventory-form" id="updateForm">
    <input type="hidden" name="inv_id" id="inv_id" value="<%= locals.inv_id || '' %>" />

    <label for="classificationList">Classification</label>
    <%- classificationList %>

    <label for="inv_make">Make</label>
    <input
      type="text"
      name="inv_make"
      id="inv_make"
      placeholder="Enter vehicle make"
      value="<%= locals.inv_make || '' %>"
      required
    />

    <label for="inv_model">Model</label>
    <input
      type="text"
      name="inv_model"
      id="inv_model"
      placeholder="Enter vehicle model"
      value="<%= locals.inv_model || '' %>"
      required
    />

    <label for="inv_year">Year</label>
    <input
      type="text"
      name="inv_year"
      id="inv_year"
      inputmode="numeric"
      pattern="\d{4}"
      maxlength="4"
      placeholder="Enter 4-digit year"
      value="<%= locals.inv_year || '' %>"
      required
    />

    <label for="inv_description">Description</label>
    <textarea
      name="inv_description"
      id="inv_description"
      rows="5"
      minlength="10"
      placeholder="Describe the vehicle"
      required
    ><%= locals.inv_description || '' %></textarea>

    <label for="inv_image">Image Path</label>
    <input
      type="text"
      name="inv_image"
      id="inv_image"
      placeholder="/images/vehicles/no-image.png"
      pattern="^/images/vehicles/[A-Za-z0-9._-]+\.(jpg|jpeg|png|gif|webp)$"
      title="Use a path inside /images/vehicles/ with a supported image file extension."
      value="<%= locals.inv_image || '/images/vehicles/no-image.png' %>"
      required
    />

    <label for="inv_thumbnail">Thumbnail Path</label>
    <input
      type="text"
      name="inv_thumbnail"
      id="inv_thumbnail"
      placeholder="/images/vehicles/no-image-tn.png"
      pattern="^/images/vehicles/[A-Za-z0-9._-]+\.(jpg|jpeg|png|gif|webp)$"
      title="Use a path inside /images/vehicles/ with a supported image file extension."
      value="<%= locals.inv_thumbnail || '/images/vehicles/no-image-tn.png' %>"
      required
    />

    <label for="inv_price">Price</label>
    <input
      type="number"
      name="inv_price"
      id="inv_price"
      min="0"
      step="0.01"
      placeholder="Enter price"
      value="<%= locals.inv_price || '' %>"
      required
    />

    <label for="inv_miles">Mileage</label>
    <input
      type="number"
      name="inv_miles"
      id="inv_miles"
      min="0"
      step="1"
      placeholder="Enter mileage"
      value="<%= locals.inv_miles || '' %>"
      required
    />

    <label for="inv_color">Color</label>
    <input
      type="text"
      name="inv_color"
      id="inv_color"
      placeholder="Enter vehicle color"
      value="<%= locals.inv_color || '' %>"
      required
    />

    <button type="submit" class="btn inventory-btn" disabled>Update Vehicle</button>
  </form>
</section>

<script src="/js/inv-update.js"></script>
