<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<h1><%= title %></h1>

<section class="inventory-panel inventory-panel--wide search-panel">
  <p class="form-note">
    Search inventory by make, model, description, or classification. Use the filter to narrow the results or leave it on All Classifications.
  </p>

  <form action="/inv/search" method="post" class="inventory-form search-form">
    <label for="search_term">Search Term</label>
    <input
      type="text"
      name="search_term"
      id="search_term"
      placeholder="Enter a make, model, or keyword"
      minlength="2"
      maxlength="50"
      value="<%= locals.search_term || '' %>"
      required
    />

    <label for="classificationList">Classification Filter</label>
    <%- classificationList %>

    <button type="submit" class="btn inventory-btn">Search Inventory</button>
  </form>

  <p>
    <a class="btn" href="/inv/">Back to Inventory Management</a>
  </p>

  <% if (hasSearched) { %>
    <section class="inventory-search-results">
      <h2>Search Results</h2>

      <% if (results.length > 0) { %>
        <p class="inventory-search-results__summary">
          <%= results.length %> vehicle<%= results.length === 1 ? '' : 's' %> matched
          <strong><%= locals.search_term || '' %></strong>.
        </p>

        <table class="inventory-search-results__table">
          <thead>
            <tr>
              <th>Vehicle</th>
              <th>Classification</th>
              <th>Price</th>
              <th>Mileage</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody>
            <% results.forEach((vehicle) => { %>
              <tr>
                <td><%= vehicle.inv_year %> <%= vehicle.inv_make %> <%= vehicle.inv_model %></td>
                <td><%= vehicle.classification_name %></td>
                <td>$<%= Number(vehicle.inv_price).toLocaleString('en-US') %></td>
                <td><%= Number(vehicle.inv_miles).toLocaleString('en-US') %></td>
                <td><a href="/inv/detail/<%= vehicle.inv_id %>">View</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p class="notice">
          No vehicles matched your search. Try a different term or a different classification filter.
        </p>
      <% } %>
    </section>
  <% } %>
</section>
