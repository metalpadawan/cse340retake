<%- messages() %>

<h1><%= title %></h1>

<section class="inventory-management">
  <p class="form-note">
    Manage classifications and inventory records from this page.
  </p>

  <div class="management-links">
    <a class="management-link-card" href="/inv/add-classification">
      <h2>Add Classification</h2>
      <p>Create a new vehicle classification for the navigation and inventory system.</p>
    </a>

    <a class="management-link-card" href="/inv/add-inventory">
      <h2>Add Inventory</h2>
      <p>Add a new vehicle and assign it to one of the existing classifications.</p>
    </a>
  </div>

  <section class="inventory-selection">
    <h2>Manage Inventory</h2>
    <p class="form-note">
      Select a classification to view the vehicles in that group.
    </p>

    <div class="inventory-selection__control">
      <label for="classificationList">Vehicle Classification</label>
      <%- classificationSelect %>
    </div>

    <table id="inventoryDisplay"></table>
    <noscript>JavaScript must be enabled to use this page.</noscript>
  </section>
</section>

<script src="../../js/inventory.js"></script>
