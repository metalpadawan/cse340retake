<!-- Hero section featuring the highlighted vehicle on the home page. -->
<h1>Welcome to CSE Motors!</h1>
<%- messages() %>

<section class="hero">
  <img src="/images/vehicles/delorean.jpg" alt="Silver Delorean parked in front of a city street" />
  <div class="hero-card">
    <h2>Delorean</h2>
    <p>3 Cup Holders</p>
    <p>Superman doors</p>
    <p>Fuzzy dice!</p>
    <a class="btn" href="#">Own Today</a>
  </div>
</section>

<!-- Two-column area for featured upgrades and customer reviews. -->
<section class="home-grid">
  <div>
    <h2>Delorean Upgrades</h2>
    <div class="upgrades-grid">
      <a class="upgrade-card" href="#">
        <img src="/images/upgrades/flux-cap.png" alt="Flux capacitor" />
        <span>Flux Capacitor</span>
      </a>
      <a class="upgrade-card" href="#">
        <img src="/images/upgrades/flame.jpg" alt="Flame decal" />
        <span>Flame Decals</span>
      </a>
      <a class="upgrade-card" href="#">
        <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper sticker" />
        <span>Bumper Stickers</span>
      </a>
      <a class="upgrade-card" href="#">
        <img src="/images/upgrades/hub-cap.jpg" alt="Hub caps" />
        <span>Hub Caps</span>
      </a>
    </div>
  </div>

  <div>
    <h2>DMC Delorean Reviews</h2>
    <ul class="reviews">
      <li>"So fast it's almost like traveling in time."</li>
      <li>"Coolest ride on the road."</li>
      <li>"I'm feeling McFly!"</li>
      <li>"The most futuristic classic car ever."</li>
      <li>"80's living and I love it!"</li>
    </ul>
  </div>
</section>
