<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<h1><%= title %></h1>

<section class="account-management">
  <h2>Welcome <%= accountData.account_firstname %></h2>
  <p class="form-note">
    Review your account details below and use the available tools for your account type.
  </p>

  <article class="management-link-card">
    <h3>Account Details</h3>
    <p><strong>Name:</strong> <%= accountData.account_firstname %> <%= accountData.account_lastname %></p>
    <p><strong>Email:</strong> <%= accountData.account_email %></p>
    <p><strong>Account Type:</strong> <%= accountData.account_type %></p>
  </article>

  <p class="account-management__action">
    <a class="btn" href="/account/update/<%= accountData.account_id %>">Update Account Information</a>
  </p>

  <% if (accountData.account_type === "Employee" || accountData.account_type === "Admin") { %>
    <section class="account-management__inventory">
      <h3>Inventory Management</h3>
      <p>
        <a href="/inv/">Open the inventory management tools</a>
      </p>
    </section>
  <% } %>
</section>
