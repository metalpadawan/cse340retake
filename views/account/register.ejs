<%# Display flash messages if any are sent from the controller %>
<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<%# Use the title data value for the main heading %>
<h1><%= title %></h1>

<div class="register-container">
  <p class="form-note">All fields are required.</p>

  <form action="/account/register" method="post" class="register-form">
    <label for="account_firstname">First name</label>
    <input
      type="text"
      name="account_firstname"
      id="account_firstname"
      placeholder="Enter your first name"
      value="<%= locals.account_firstname || '' %>"
      required
    />

    <label for="account_lastname">Last name</label>
    <input
      type="text"
      name="account_lastname"
      id="account_lastname"
      placeholder="Enter your last name"
      value="<%= locals.account_lastname || '' %>"
      required
    />

    <label for="account_email">Email address</label>
    <input
      type="email"
      name="account_email"
      id="account_email"
      placeholder="Enter your email address"
      value="<%= locals.account_email || '' %>"
      required
    />

    <label for="account_password">Password</label>
    <div class="password-hint" id="register-password-requirements">
      Passwords must be at least 12 characters and include 1 number,
      1 lowercase letter, 1 uppercase letter, and 1 special character.
    </div>

    <div class="password-wrapper">
      <input
        type="password"
        name="account_password"
        id="account_password"
        placeholder="Enter your password"
        aria-describedby="register-password-requirements"
        pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$"
        title="Password must be at least 12 characters and include 1 number, 1 lowercase letter, 1 uppercase letter, and 1 special character."
        required
      />
      <%# Toggle button to show/hide password %>
      <button
        type="button"
        id="togglePassword"
        class="toggle-password"
        aria-label="Show password"
        aria-pressed="false"
      >Show</button>
    </div>

    <button type="submit" class="btn register-btn">Register</button>
  </form>
</div>

<script>
  // Toggle the password input between visible text and hidden bullets.
  const togglePassword = document.getElementById('togglePassword')
  const passwordInput = document.getElementById('account_password')

  togglePassword.addEventListener('click', function () {
    const showPassword = passwordInput.getAttribute('type') === 'password'
    const type = showPassword ? 'text' : 'password'

    passwordInput.setAttribute('type', type)
    this.textContent = showPassword ? 'Hide' : 'Show'
    this.setAttribute('aria-label', showPassword ? 'Hide password' : 'Show password')
    this.setAttribute('aria-pressed', showPassword ? 'true' : 'false')
  })
</script>
